# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║                     ENTERPRISE AI AGENT - CONFIG SETUP                     ║
# ║                                                                             ║
# ║  Copy this file to .env and add your actual API keys                       ║
# ║  IMPORTANT: Never commit .env to version control                           ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# ─────────────────────────────────────────────────────────────────────────────
# CORE LLM & SEARCH (REQUIRED)
# ─────────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# LEAD GENERATION (OPTIONAL - for Phase 1)
# ─────────────────────────────────────────────────────────────────────────────
# Apollo.io - https://apollo.io/developers
APOLLO_API_KEY=

# Hunter.io - https://hunter.io/api
HUNTER_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL & OUTREACH (OPTIONAL - for Phase 1)
# ─────────────────────────────────────────────────────────────────────────────
# SendGrid - https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourcompany.com

# ─────────────────────────────────────────────────────────────────────────────
# CALENDAR & MEETINGS (OPTIONAL - for Phase 1)
# ─────────────────────────────────────────────────────────────────────────────
# Google Calendar - Follow: https://developers.google.com/calendar/api/quickstart/python
# Save credentials JSON to backend/config/google-credentials.json
GOOGLE_CALENDAR_CREDENTIALS_PATH=./config/google-credentials.json
GOOGLE_CALENDAR_EMAIL=your-email@gmail.com

# ─────────────────────────────────────────────────────────────────────────────
# SMS & VOICE (OPTIONAL - for Phase 2)
# ─────────────────────────────────────────────────────────────────────────────
# Twilio - https://www.twilio.com/console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1234567890

# ─────────────────────────────────────────────────────────────────────────────
# LINKEDIN (OPTIONAL - for Phase 2)
# ─────────────────────────────────────────────────────────────────────────────
LINKEDIN_API_KEY=
LINKEDIN_OAUTH_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# CRM SYSTEMS (OPTIONAL - for Phase 2)
# ─────────────────────────────────────────────────────────────────────────────
# HubSpot - https://app.hubspot.com/l/settings/api-key
HUBSPOT_API_KEY=

# Salesforce - https://login.salesforce.com/services/oauth2/authorize
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_INSTANCE_URL=https://your-instance.salesforce.com

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE (OPTIONAL - for production)
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./flowforge.db
# For PostgreSQL: postgresql://user:password@localhost/flowforge_db

# ─────────────────────────────────────────────────────────────────────────────
# APP SETTINGS
# ─────────────────────────────────────────────────────────────────────────────
APP_ENV=development
API_PORT=8000

# ═══════════════════════════════════════════════════════════════════════════════
# SETUP INSTRUCTIONS
# ═══════════════════════════════════════════════════════════════════════════════
#
# 1. MINIMUM SETUP (to get started):
#    ✓ GROQ_API_KEY     - Get from https://console.groq.com
#    ✓ TAVILY_API_KEY   - Get from https://tavily.com
#
# 2. PHASE 1 SETUP (add lead generation + email):
#    ✓ APOLLO_API_KEY       - Get from https://apollo.io/api
#    ✓ SENDGRID_API_KEY     - Get from https://sendgrid.com
#    ✓ GOOGLE_CALENDAR_*    - Follow Google Calendar API setup guide
#
# 3. PHASE 2 SETUP (add SMS + CRM sync):
#    ✓ TWILIO_*             - Get from https://www.twilio.com
#    ✓ HUBSPOT_API_KEY      - Get from HubSpot settings
#
# Each integration gracefully falls back to mock data if no API key is provided.
# You can test the entire system without any API keys!
#
# ═══════════════════════════════════════════════════════════════════════════════
